# AutoSoc 配置模板 — 复制为 .env 并按需修改

# 数据库
AUTOSOC_DB_PATH=data/autosoc.db

# AI Provider (mock / openai / ollama)
AUTOSOC_AI_PROVIDER=mock
# AUTOSOC_OPENAI_API_KEY=sk-xxx
# AUTOSOC_OPENAI_MODEL=gpt-4o
# AUTOSOC_OLLAMA_BASE_URL=http://localhost:11434
# AUTOSOC_OLLAMA_MODEL=llama3

# 存储
AUTOSOC_STORAGE_ROOT=storage

# 浏览器自动化
AUTOSOC_PLAYWRIGHT_HEADLESS=true
AUTOSOC_PLAYWRIGHT_SLOW_MO=200

# 日志
AUTOSOC_LOG_LEVEL=INFO
AUTOSOC_LOG_FILE=data/autosoc.log

# 系统阶段 (manual / cooperative / autonomous)
AUTOSOC_SYSTEM_PHASE=manual
